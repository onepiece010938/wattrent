# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Plan output
*.tfplan
*tfplan*

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration
.terraformrc
terraform.rc
credentials.tfrc.json

# Local override tfvars (containing billing account / token / other secrets)
envs/*.local.tfvars
*.auto.tfvars
*.auto.tfvars.json
!*.tfvars.example

# Cloud Function build artifacts
modules/**/.build/

# Lock file is committed; do not ignore.
# .terraform.lock.hcl

