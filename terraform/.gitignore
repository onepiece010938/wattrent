# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Plan output
*.tfplan
*tfplan*

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration
.terraformrc
terraform.rc
credentials.tfrc.json

# 本地 override tfvars（含 billing account / token 等敏感值）
envs/*.local.tfvars
*.auto.tfvars
*.auto.tfvars.json
!*.tfvars.example

# Cloud Function 打包暫存
modules/**/.build/

# Lock file 要進版本控管，不要 ignore
# .terraform.lock.hcl

