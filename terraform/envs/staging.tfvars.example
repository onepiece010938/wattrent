# 範本：複製成 envs/staging.local.tfvars 後填值（會被 .gitignore 忽略）
#
# 用法：
#   cp envs/staging.tfvars.example envs/staging.local.tfvars
#   # 編輯 envs/staging.local.tfvars
#   terraform plan -var-file="envs/staging.tfvars" -var-file="envs/staging.local.tfvars"
#
# TFC remote runs 不需要這個檔；TFC workspace 上的 variables 會直接注入。

gcp_billing_account   = "XXXXXX-XXXXXX-XXXXXX"
# cloudflare_zone_id  = "..."
# sentry_organization = "..."
# github_repository   = "your-handle/wattrent"
