# Template: copy to envs/staging.local.tfvars and fill in values (it is gitignored).
#
# Usage:
#   cp envs/staging.tfvars.example envs/staging.local.tfvars
#   # edit envs/staging.local.tfvars
#   terraform plan -var-file="envs/staging.tfvars" -var-file="envs/staging.local.tfvars"
#
# TFC remote runs do not need this file; the workspace variables on TFC are injected directly.

