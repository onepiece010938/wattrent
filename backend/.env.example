# ----------------------------------------------------------------------
# Backend environment variable template
# Copy to .env and source it (or set them in the container / Cloud Run).
#
# WARNING: never commit real values into the repo.
# ----------------------------------------------------------------------

# Environment: dev / staging / production / preview-{n}
APP_ENV=dev

# GCP project ID (Firestore / Storage / Vertex AI all share the same one)
GCP_PROJECT_ID=wattrent-staging

# GCP region (Firestore / GCS / Vertex AI publisher endpoint)
GCP_REGION=asia-east1

# GCS bucket for meter photos
METERS_BUCKET=wattrent-meters-staging

# HTTP port (Cloud Run injects PORT automatically)
PORT=8080

# CORS: comma-separated; production cannot use *
ALLOWED_ORIGINS=*

# Skip Firebase ID token verification; local dev only, MUST be false in production
AUTH_BYPASS=true
AUTH_BYPASS_UID=dev-user

# AI backend choice:
#   gemini (default) = Google AI Studio Gemini API, free tier (1500 RPD on flash-lite)
#                      Requires GEMINI_API_KEY; free-tier data may be used by Google for training
#   vertex          = GCP Vertex AI; paid, IAM-based, NOT used for training
AI_BACKEND=gemini

# AI Studio API key (get one at https://aistudio.google.com/apikey)
# Required when AI_BACKEND=gemini; can be left blank when AI_BACKEND=vertex
GEMINI_API_KEY=

# Gemini model (shared by both backends)
GEMINI_MODEL=gemini-2.5-flash-lite

# Sentry (optional; empty string disables it)
SENTRY_DSN=

# Application Default Credentials (for local use)
# Not needed if you have run `gcloud auth application-default login`
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\sa-key.json
