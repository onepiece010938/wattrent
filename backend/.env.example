# ──────────────────────────────────────────────────────────────────────────
# 後端環境變數範例
# 複製成 .env 後 source 進去（或在容器 / Cloud Run 設定）
#
# ⚠️ 請勿把真實值 commit 進 repo
# ──────────────────────────────────────────────────────────────────────────

# 環境：dev / staging / production / preview-{n}
APP_ENV=dev

# GCP project ID（Firestore / Storage / Vertex AI 後端都用同一個）
GCP_PROJECT_ID=wattrent-staging

# GCP region（Firestore / GCS / Vertex AI publisher endpoint）
GCP_REGION=asia-east1

# 電表照片 GCS bucket
METERS_BUCKET=wattrent-meters-staging

# HTTP port（Cloud Run 會自動帶 PORT）
PORT=8080

# CORS：逗號分隔；production 不可用 *
ALLOWED_ORIGINS=*

# 跳過 Firebase ID token 驗證；僅本地開發用，production 強制 false
AUTH_BYPASS=true
AUTH_BYPASS_UID=dev-user

# AI 後端選擇：
#   gemini（預設）= Google AI Studio Gemini API，免費 tier（1500 RPD on flash-lite）
#                 要 GEMINI_API_KEY，免費資料可能被 Google 拿去訓練
#   vertex      = GCP Vertex AI，要錢、走 IAM、資料不訓練
AI_BACKEND=gemini

# AI Studio API key（在 https://aistudio.google.com/apikey 取得）
# AI_BACKEND=gemini 時必填；AI_BACKEND=vertex 可留空
GEMINI_API_KEY=

# Gemini 模型（兩個 backend 共用）
GEMINI_MODEL=gemini-2.5-flash-lite

# Sentry（可選，空字串代表停用）
SENTRY_DSN=

# Application Default Credentials（local 用）
# 跑 `gcloud auth application-default login` 後不必設
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\sa-key.json
