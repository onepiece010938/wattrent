# ──────────────────────────────────────────────────────────────────────────
# 後端環境變數範例
# 複製成 .env 後 source 進去（或在容器 / Cloud Run 設定）
#
# ⚠️ 請勿把真實值 commit 進 repo
# ──────────────────────────────────────────────────────────────────────────

# 環境：dev / staging / production / preview-{n}
APP_ENV=dev

# GCP project ID（Firestore / Storage / Vertex AI 都用同一個）
GCP_PROJECT_ID=wattrent-staging

# GCP region（Vertex AI publisher endpoint）
GCP_REGION=asia-east1

# 電表照片 GCS bucket
METERS_BUCKET=wattrent-meters-staging

# HTTP port（Cloud Run 會自動帶 PORT）
PORT=8080

# CORS：逗號分隔；production 不可用 *
ALLOWED_ORIGINS=*

# 跳過 Firebase ID token 驗證；僅本地開發用，production 強制 false
AUTH_BYPASS=true
AUTH_BYPASS_UID=dev-user

# Vertex AI Gemini 模型
VERTEX_MODEL=gemini-2.5-flash-lite

# Sentry（可選，空字串代表停用）
SENTRY_DSN=

# Application Default Credentials（local 用）
# 跑 `gcloud auth application-default login` 後不必設
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\sa-key.json
