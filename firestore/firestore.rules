rules_version = '2';

// WattRent Firestore Security Rules
//
// Design principles:
//   1. Always go through Firebase Auth; reject everything unauthenticated.
//   2. Users can only read/write their own data under /users/{uid}/...
//   3. Writes do minimal validation (types, required fields, value ranges);
//      complex logic is handled by the backend Admin SDK.
//   4. The backend Cloud Run service account uses the Admin SDK and
//      bypasses these rules.
//
// See docs/firestore-schema.md for the full design.

service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────── helpers ───────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isPositiveNumber(v) {
      return v is number && v >= 0;
    }

    function isNonEmptyString(v) {
      return v is string && v.size() > 0;
    }

    // ─────────────────── /users/{userId} ───────────────────

    match /users/{userId} {
      allow read: if isOwner(userId);

      // Created on first sign-in; must match the Auth token
      allow create: if isOwner(userId)
                    && request.resource.data.email == request.auth.token.email
                    && request.resource.data.createdAt == request.time
                    && request.resource.data.updatedAt == request.time;

      // email / createdAt are immutable
      allow update: if isOwner(userId)
                    && request.resource.data.email == resource.data.email
                    && request.resource.data.createdAt == resource.data.createdAt
                    && request.resource.data.updatedAt == request.time;

      // Account deletion goes through the backend (soft delete)
      allow delete: if false;

      // ─────── /users/{userId}/settings/{docId} ───────
      match /settings/{docId} {
        allow read: if isOwner(userId);

        allow write: if isOwner(userId)
                     && docId == 'current'
                     && isPositiveNumber(request.resource.data.defaultElectricityRate)
                     && isPositiveNumber(request.resource.data.defaultRent)
                     && isPositiveNumber(request.resource.data.previousMeterReading)
                     && request.resource.data.updatedAt == request.time;
      }

      // ─────── /users/{userId}/bills/{billId} ───────
      match /bills/{billId} {
        allow read: if isOwner(userId);

        allow create: if isOwner(userId)
                      && isPositiveNumber(request.resource.data.meterReading)
                      && isPositiveNumber(request.resource.data.previousReading)
                      && request.resource.data.meterReading >= request.resource.data.previousReading
                      && isPositiveNumber(request.resource.data.electricityRate)
                      && isPositiveNumber(request.resource.data.rent)
                      && isNonEmptyString(request.resource.data.period)
                      && request.resource.data.createdAt == request.time
                      && request.resource.data.updatedAt == request.time;

        // From the client, only paidAt + updatedAt may be modified
        // (mark-as-paid). All other field changes must go through the
        // backend Admin SDK.
        allow update: if isOwner(userId)
                      && request.resource.data.diff(resource.data)
                          .affectedKeys()
                          .hasOnly(['paidAt', 'updatedAt']);

        // Paid bills cannot be deleted
        allow delete: if isOwner(userId)
                      && resource.data.paidAt == null;
      }
    }

    // ─────────────────── default deny ───────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
