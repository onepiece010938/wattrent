# ──────────────────────────────────────────────────────────────────────────
# WattRent root .gitignore
# 子目錄（frontend/、terraform/、backend/）有更細的 ignore 規則
# ──────────────────────────────────────────────────────────────────────────

# === Go ===
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
go.work
go.work.sum

# Air 熱重載輸出
**/tmp/
*/tmp

# === Node / Expo / 前端產物 ===
node_modules/
dist/
build/
.expo/
web-build/
tmp-web-bundle/
.metro-health-check*
*.tsbuildinfo

# === 環境變數 / Secret（一律不進 repo） ===
.env
.env.*
!.env.example
*.local
*.local.*
!*.local.example

# Service account / OIDC / Auth credentials
*-key.json
*service-account*.json
gha-creds-*.json
firebase-adminsdk-*.json
credentials.tfrc.json
.terraformrc
terraform.rc

# Local notes containing secrets / API keys / PATs (never commit)
TOKEN.txt
TOKENS.txt
secrets.txt
*.secret
.commit-msg.tmp

# === Terraform local artefacts（terraform/.gitignore 也有） ===
**/.terraform/
*.tfstate
*.tfstate.*
*.tfplan
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraform.tfstate.lock.info

# Local override tfvars（含真實 billing account / domain）
# 共用值請放 TFC workspace variables；個人實驗用 *.local.tfvars
**/envs/*.local.tfvars
**/*.auto.tfvars
**/*.auto.tfvars.json
!**/*.tfvars.example

# === IDE / OS ===
.vscode/
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
desktop.ini

# === 日誌 / 暫存 ===
*.log
logs/
*.bak
*.swp
*~

# === Cloud Function 打包暫存 ===
**/.build/
**/__pycache__/
*.pyc

# === 其他 ===
coverage/
.nyc_output/
