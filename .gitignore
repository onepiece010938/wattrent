# ──────────────────────────────────────────────────────────────────────────
# WattRent root .gitignore
# Subdirectories (frontend/, terraform/, backend/) have more specific rules.
# ──────────────────────────────────────────────────────────────────────────

# === Go ===
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
go.work
go.work.sum

# Air hot-reload output
**/tmp/
*/tmp

# === Node / Expo / frontend build artefacts ===
node_modules/
dist/
build/
.expo/
web-build/
tmp-web-bundle/
.metro-health-check*
*.tsbuildinfo

# === Environment variables / secrets (never commit) ===
.env
.env.*
!.env.example
*.local
*.local.*
!*.local.example

# Service account / OIDC / Auth credentials
*-key.json
*service-account*.json
gha-creds-*.json
firebase-adminsdk-*.json
credentials.tfrc.json
.terraformrc
terraform.rc

# Local notes containing secrets / API keys / PATs (never commit)
TOKEN.txt
TOKENS.txt
secrets.txt
*.secret
.commit-msg.tmp

# Local-only docs (private design notes, not for public repo)
docs/

# === Terraform local artefacts (terraform/.gitignore also covers these) ===
**/.terraform/
*.tfstate
*.tfstate.*
*.tfplan
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraform.tfstate.lock.info

# Local override tfvars (with real billing accounts / domains).
# Put shared values in TFC workspace variables; personal experiments
# use *.local.tfvars.
**/envs/*.local.tfvars
**/*.auto.tfvars
**/*.auto.tfvars.json
!**/*.tfvars.example

# === IDE / OS ===
.vscode/
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
desktop.ini

# === Logs / temp files ===
*.log
logs/
*.bak
*.swp
*~

# === Cloud Function packaging temp ===
**/.build/
**/__pycache__/
*.pyc

# === Misc ===
coverage/
.nyc_output/
