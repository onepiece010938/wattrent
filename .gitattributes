# ──────────────────────────────────────────────────────────────────────────
# Force all source files to use LF, so Windows `core.autocrlf=true` does not
# write CRLF into git blobs and then make gofmt / prettier / etc. on Linux
# runners endlessly complain about needing reformatting.
#
# Rule order: first default to text=auto, then force lf / mark binary for
# specific extensions.
# ──────────────────────────────────────────────────────────────────────────

# Default: let git auto-detect text/binary, normalise to LF on commit,
# convert per-platform on checkout.
* text=auto eol=lf

# Source code / config files: always LF
*.go        text eol=lf
*.mod       text eol=lf
*.sum       text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.json      text eol=lf
*.json5     text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.tf        text eol=lf
*.tfvars    text eol=lf
*.hcl       text eol=lf
*.sh        text eol=lf
*.py        text eol=lf
*.md        text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.svg       text eol=lf
*.proto     text eol=lf

# Dockerfile / Makefile and other extension-less files
Dockerfile     text eol=lf
Dockerfile.*   text eol=lf
Makefile       text eol=lf
justfile       text eol=lf
.dockerignore  text eol=lf
.gitignore     text eol=lf
.gitattributes text eol=lf
.editorconfig  text eol=lf
.env.example   text eol=lf

# Windows-only scripts keep CRLF
*.ps1       text eol=crlf
*.psm1      text eol=crlf
*.bat       text eol=crlf
*.cmd       text eol=crlf

# Binary files (do not apply line-ending handling or diffs)
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.ico       binary
*.pdf       binary
*.zip       binary
*.gz        binary
*.tar       binary
*.ttf       binary
*.otf       binary
*.woff      binary
*.woff2     binary
*.eot       binary
*.mp3       binary
*.mp4       binary
*.wav       binary

# Lock files: text, but hide from GitHub diff view
package-lock.json  text eol=lf linguist-generated=true
yarn.lock          text eol=lf linguist-generated=true
go.sum             text eol=lf linguist-generated=true
